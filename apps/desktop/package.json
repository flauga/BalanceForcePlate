{
  "name": "force-plate-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Force Plate Balance Board Desktop App",
  "main": "electron-main.js",
  "author": "flauga",
  "license": "MIT",
  "scripts": {
    "start": "node start.js",
    "dist": "electron-builder --win",
    "dist:publish": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.flauga.force-plate",
    "productName": "Force Plate Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-main.js"
    ],
    "extraResources": [
      {
        "from": "server-bundle/dist",
        "to": "server/dist"
      },
      {
        "from": "server-bundle/public",
        "to": "server/public"
      },
      {
        "from": "server-bundle/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "server-bundle/package.json",
        "to": "server/package.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Force Plate Dashboard"
    },
    "publish": {
      "provider": "github",
      "owner": "flauga",
      "repo": "BalanceForcePlate"
    }
  }
}
